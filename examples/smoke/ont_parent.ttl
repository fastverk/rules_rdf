@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex:   <http://example.org/parent#> .
@prefix child: <http://example.org/child#> .

<http://example.org/parent> a owl:Ontology ;
    owl:imports <http://example.org/child> .

ex:Dog rdfs:subClassOf child:Animal .
